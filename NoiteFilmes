                html += `<button data-genre="${genre}" class="genre-filter px-3 py-1 rounded-full bg-gray-800 hover:bg-gray-700 transition text-xs">${genre}</button>`;
            });
            document.getElementById('genreFilters').innerHTML = html;
            
            document.querySelectorAll('.genre-filter').forEach(btn => {
                if(btn.getAttribute('data-genre') === currentGenreFilter) btn.classList.add('genre-filter-active');
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.genre-filter').forEach(b => b.classList.remove('genre-filter-active'));
