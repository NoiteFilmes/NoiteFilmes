        // Funções existentes (adaptadas para Firebase)
        function extractYoutubeId(url) {
            if(!url) return null;
            const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
            const match = url.match(regExp);
            return (match && match[2].length === 11) ? match[2] : null;
        }
        
        async function fetchYouTubeMetadata(url) {
            const videoId = extractYoutubeId(url);
            if (!videoId) return null;
            try {
                const oembedRes = await fetch(`https://www.youtube.com/oembed?url=https://www.youtube.com/watch?v=${videoId}&format=json`);
                const oembedData = await oembedRes.json();
                let year = new Date().getFullYear();
                let genre = 'Geral';
                return {
                    title: oembedData.title || 'Sem título',
                    thumb: oembedData.thumbnail_url || `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`,
                    description: 'Sem descrição',
                    year: year,
                    genre: genre,
                    link: url
                };
            } catch(e) {
                return null;
            }
        }
        
        function playMedia(item, type) {
            const playerSection = document.getElementById('playerSection');
            playerSection.classList.remove('hidden');
            
            const hlsVideo = document.getElementById('hlsPlayer');
            const youtubeDiv = document.getElementById('youtubePlayerDiv');
            const noContent = document.getElementById('noContent');
            
            youtubeDiv.style.display = 'block';
            hlsVideo.style.display = 'none';
            if(window.hlsInstance) { window.hlsInstance.destroy(); window.hlsInstance = null; }
            
            currentMedia = item;
            currentMediaType = type;
            document.getElementById('currentMediaTitle').innerText = item.title;
            document.getElementById('currentMediaDesc').innerText = item.description || 'Sem descrição disponível';
            document.getElementById('mediaYear').innerHTML = item.year ? `📅 ${item.year}` : '';
            document.getElementById('mediaGenre').innerHTML = item.category ? `🎭 ${item.category}` : '';
            
            noContent.style.display = 'flex';
            noContent.innerHTML = '🎬 Carregando vídeo...';
            
            if(type === 'filme' || type === 'serie') {
                const vidId = extractYoutubeId(item.link);
                if(vidId && ytPlayer) {
                    ytPlayer.loadVideoById(vidId);
                    if(progressSalvos[item.id] && progressSalvos[item.id] > 5) {
                        setTimeout(() => {
                            if(ytPlayer && ytPlayer.seekTo) {
                                ytPlayer.seekTo(progressSalvos[item.id], true);
                            }
                        }, 1500);
                    }
                } else {
                    alert("Link inválido");
                    noContent.style.display = 'none';
                }
            }
        }
        
        function onYouTubeIframeAPIReady() {
            ytPlayer = new YT.Player('youtubePlayerDiv', {
                height: '100%',
                width: '100%',
                videoId: '',
                playerVars: { 'autoplay': 1, 'controls': 1, 'modestbranding': 1, 'rel': 0, 'showinfo': 0, 'fs': 1, 'playsinline': 1 },
                events: {
                    'onReady': onPlayerReady,
                    'onStateChange': onPlayerStateChange
                }
            });
        }
        
        function onPlayerReady(event) {
            isPlayerReady = true;
            if(currentMedia && (currentMediaType === 'filme' || currentMediaType === 'serie')) {
                const savedTime = progressSalvos[currentMedia.id];
                if(savedTime && savedTime > 5) {
                    event.target.seekTo(savedTime, true);
                }
                event.target.playVideo();
            }
        }
        
        function onPlayerStateChange(event) {
            if(event.data === YT.PlayerState.PLAYING && currentMedia && currentUser) {
                if(window.progressInterval) clearInterval(window.progressInterval);
                window.progressInterval = setInterval(() => {
                    if(ytPlayer && ytPlayer.getCurrentTime) {
                        const currentTime = ytPlayer.getCurrentTime();
                        if(currentMedia && currentTime > 0) {
                            database.ref(`progresso/${currentUser.uid}/${currentMedia.id}`).set(currentTime);
                        }
                    }
                }, 5000);
            }
        }
        
