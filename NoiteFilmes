<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>NoiteFilmes - com Firebase</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/hls.js@1.5.8/dist/hls.min.js"></script>
    <script src="https://www.youtube.com/iframe_api"></script>
    
    <!-- Firebase SDKs -->
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-database-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        /* Seus estilos existentes aqui */
        * { box-sizing: border-box; }
        body { background-color: #0a0a0a; overflow-x: hidden; }
        .player-wrapper { background: #000; position: relative; padding-bottom: 56.25%; height: 0; }
        .player-wrapper iframe, .player-wrapper video { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }
        .card-hover:hover { transform: scale(1.02); transition: 0.2s; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.5); }
        .active-tab { color: #e50914 !important; }
        .like-btn.active { color: #ff4d4d; }
        .save-btn.active { color: #ffd700; }
        .toast { position: fixed; bottom: 20px; right: 20px; background: #333; color: white; padding: 10px 20px; border-radius: 8px; z-index: 1000; animation: fadeOut 3s forwards; }
        @keyframes fadeOut { 0% { opacity: 1; } 70% { opacity: 1; } 100% { opacity: 0; visibility: hidden; } }
        .watermark {
            position: fixed;
            bottom: 20px;
            left: 20px;
            z-index: 999;
            background: rgba(0,0,0,0.7);
            padding: 8px 15px;
            border-radius: 30px;
            font-size: 14px;
            font-weight: bold;
            backdrop-filter: blur(5px);
            pointer-events: none;
            font-family: monospace;
            border: 1px solid #e50914;
            color: white;
        }
        .watermark i { color: #e50914; margin-right: 5px; }
        .genre-filter-active { background-color: #e50914 !important; color: white !important; }
        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            cursor: pointer;
            transition: all 0.2s;
            padding: 6px 12px;
            border-radius: 8px;
        }
        .nav-item i { font-size: 20px; }
        .nav-item span { font-size: 11px; font-weight: 500; }
        .nav-item:hover { background-color: rgba(229, 9, 20, 0.1); }
        .nav-item.active { color: #e50914; }
        
        .carousel-container {
            position: relative;
            overflow-x: auto;
            scroll-behavior: smooth;
            scrollbar-width: thin;
            -webkit-overflow-scrolling: touch;
        }
        .carousel-container::-webkit-scrollbar { height: 4px; }
        .carousel-container::-webkit-scrollbar-track { background: #1f1f1f; border-radius: 10px; }
        .carousel-container::-webkit-scrollbar-thumb { background: rgba(229, 9, 20, 0.5); border-radius: 10px; }
        .carousel-track {
            display: flex;
            gap: 16px;
            padding: 4px 0;
        }
        .carousel-item {
            flex: 0 0 calc(20% - 13px);
            min-width: 0;
            transition: transform 0.2s;
            position: relative;
        }
        @media (max-width: 640px) {
            .carousel-track { gap: 12px; }
            .carousel-item { flex: 0 0 calc(20% - 10px); }
        }
        .carousel-item:hover { transform: scale(1.03); z-index: 10; }
        
        .carousel-item .poster-wrapper {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
        }
        .carousel-item .poster-back {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: blur(8px);
            transform: scale(1.1);
            z-index: 0;
        }
        .carousel-item .poster-front {
            position: relative;
            width: 100%;
            aspect-ratio: 2/3;
            object-fit: contain;
            z-index: 1;
            background: transparent;
        }
        .carousel-item .rank-number {
            position: absolute;
            top: -8px;
            left: -8px;
            width: 28px;
            height: 28px;
            background: #e50914;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: bold;
            z-index: 2;
            box-shadow: 0 2px 5px rgba(0,0,0,0.3);
        }
        
        .cast-btn {
            background: rgba(0,0,0,0.7);
            border: 1px solid #e50914;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
        }
        .cast-btn:hover { background: #e50914; transform: scale(1.05); }
        .cast-btn.active { background: #e50914; color: white; }
        
        .chat-container {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 380px;
            height: 500px;
            background: #1a1a1a;
            border-radius: 20px;
            border: 1px solid #333;
            display: flex;
            flex-direction: column;
            z-index: 1000;
            transition: all 0.3s;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
        .chat-container.minimized {
            height: 60px;
            width: 280px;
        }
        .chat-header {
            padding: 12px 16px;
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            border-radius: 20px 20px 0 0;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #e50914;
        }
        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 12px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .message {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            animation: fadeIn 0.3s;
        }
        .message-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: #e50914;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: bold;
        }
        .message-content {
            background: #2a2a2a;
            padding: 8px 12px;
            border-radius: 12px;
            max-width: 70%;
        }
        .message-username {
            font-size: 11px;
            color: #e50914;
            font-weight: bold;
            margin-bottom: 4px;
        }
        .message-text {
            font-size: 13px;
            word-wrap: break-word;
        }
        .message-time {
            font-size: 9px;
            color: #666;
            margin-top: 4px;
        }
        .my-message {
            flex-direction: row-reverse;
        }
        .my-message .message-content {
            background: #e50914;
        }
        .my-message .message-username { color: #fff; }
        .chat-input-area {
            padding: 12px;
            border-top: 1px solid #333;
            display: flex;
            gap: 8px;
        }
        .chat-input {
            flex: 1;
            padding: 8px 12px;
            background: #2a2a2a;
            border: none;
            border-radius: 20px;
            color: white;
            outline: none;
        }
        .chat-send-btn {
            background: #e50914;
            border: none;
            border-radius: 50%;
            width: 36px;
            height: 36px;
            cursor: pointer;
            transition: 0.2s;
        }
        .chat-send-btn:hover { transform: scale(1.05); }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        /* Modal de Login */
        .login-modal {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.95);
            z-index: 2000;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(10px);
        }
        .login-box {
            background: #1a1a1a;
            border-radius: 20px;
            padding: 30px;
            width: 90%;
            max-width: 400px;
            border: 1px solid #e50914;
        }
        .login-input {
            width: 100%;
            padding: 12px;
            background: #2a2a2a;
            border: 1px solid #444;
            border-radius: 8px;
            color: white;
            margin-bottom: 12px;
        }
        .login-btn {
            background: #e50914;
            color: white;
            padding: 12px;
            border: none;
            border-radius: 8px;
            width: 100%;
            cursor: pointer;
            font-weight: bold;
        }
        .switch-auth {
            color: #e50914;
            cursor: pointer;
            text-align: center;
            margin-top: 12px;
        }
        
        .search-popup {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.95);
            z-index: 1000;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding-top: 80px;
            backdrop-filter: blur(10px);
        }
        .search-popup-content {
            width: 90%;
            max-width: 800px;
            background: #1a1a1a;
            border-radius: 20px;
            padding: 24px;
            border: 1px solid #333;
        }
        .search-popup input {
            width: 100%;
            padding: 16px 20px;
            font-size: 18px;
            background: #2a2a2a;
            border: 2px solid #e50914;
            border-radius: 50px;
            color: white;
            outline: none;
        }
        .batch-input {
            width: 100%;
            padding: 12px;
            background: #2a2a2a;
            border: 1px solid #444;
            border-radius: 8px;
            color: white;
            font-family: monospace;
            font-size: 12px;
        }
        .duplicate-item {
            background: rgba(229, 9, 20, 0.2);
            border-left: 3px solid #e50914;
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 8px;
            background: #1a1a1a;
            padding: 4px 12px;
            border-radius: 20px;
        }
        .logout-btn {
            background: none;
            border: none;
            color: #e50914;
            cursor: pointer;
            font-size: 12px;
        }
    </style>
</head>
