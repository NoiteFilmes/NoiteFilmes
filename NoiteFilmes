        // Carregar dados do Firebase
        async function loadAllData() {
            showToast('🔄 Carregando dados do Firebase...');
            
            // Carregar filmes
            database.ref('filmes').on('value', (snapshot) => {
                const data = snapshot.val();
                filmes = data ? Object.values(data) : [];
                if (filmes.length === 0) loadDefaultFilmes();
                renderGrid();
                generateWeeklyTop10();
                updateGenreFilters();
            });
            
            // Carregar séries
            database.ref('series').on('value', (snapshot) => {
                const data = snapshot.val();
                series = data ? Object.values(data) : [];
                if (series.length === 0) loadDefaultSeries();
                renderGrid();
                generateWeeklyTop10();
            });
            
            // Carregar canais
            database.ref('canais').on('value', (snapshot) => {
                const data = snapshot.val();
                canais = data ? Object.values(data) : [];
                if (canais.length === 0) loadDefaultCanais();
                if (currentNavTab === 'canais') renderGrid();
            });
            
            // Carregar favoritos do usuário
            if (currentUser) {
                database.ref(`favoritos/${currentUser.uid}`).on('value', (snapshot) => {
                    const data = snapshot.val();
                    favoritos = data ? Object.values(data) : [];
                    updateLikeButton();
                    updateSaveButton();
                });
                
                database.ref(`progresso/${currentUser.uid}`).on('value', (snapshot) => {
                    progressSalvos = snapshot.val() || {};
                });
            }
            
            // Carregar Top 10
            database.ref('top10').on('value', (snapshot) => {
                const data = snapshot.val();
                if (data) {
                    top10List = data;
                    renderTop10Carousel();
                } else {
                    generateWeeklyTop10();
                }
            });
            
            // Carregar chat
            database.ref('chat').limitToLast(100).on('child_added', (snapshot) => {
                const msg = snapshot.val();
                addMessageToChat(msg.username, msg.text, msg.isSystem, msg.time, false);
            });
        }
        
