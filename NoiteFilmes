        async function previewBatch() {
            const linksText = document.getElementById('batchLinksInput').value;
            const links = linksText.split('\n').filter(l => l.trim() && extractYoutubeId(l.trim()));
            const previewDiv = document.getElementById('batchPreview');
            previewDiv.innerHTML = '<div class="text-yellow-500">🔄 Buscando dados...</div>';
            
            const items = [];
            for(let link of links) {
                const metadata = await fetchYouTubeMetadata(link.trim());
                if(metadata) items.push(metadata);
            }
            batchPreviewItems = items;
            previewDiv.innerHTML = items.map((item, idx) => `<div class="p-2 border-b border-gray-700"><strong>${item.title}</strong><br><span class="text-xs text-gray-400">${item.genre} • ${item.year}</span></div>`).join('');
        }
        
        async function saveBatch() {
            if(batchPreviewItems.length === 0) { showToast('Pré-visualize primeiro'); return; }
            for(let item of batchPreviewItems) {
                const newId = Date.now() + '-' + Math.random().toString(36);
                database.ref(`filmes/${newId}`).set({
                    id: newId,
                    title: item.title,
                    link: item.link,
                    thumb: item.thumb,
                    category: item.genre,
                    year: item.year,
                    description: item.description
                });
            }
            showToast(`✅ ${batchPreviewItems.length} filmes adicionados!`);
            document.getElementById('batchLinksInput').value = '';
            document.getElementById('batchPreview').innerHTML = '';
            batchPreviewItems = [];
        }
        
        async function saveEpisodes() {
            const serieName = document.getElementById('serieTitle').value.trim();
            const episodesText = document.getElementById('episodesLinksInput').value;
            if(!serieName) { alert('Digite o nome da série'); return; }
            
            const lines = episodesText.split('\n').filter(l => l.trim());
            for(let line of lines) {
                let episodeTitle = '', link = '';
                if(line.includes(':')) {
                    const parts = line.split(':');
                    episodeTitle = parts[0].trim();
                    link = parts.slice(1).join(':').trim();
                } else {
                    link = line.trim();
                    episodeTitle = `EP${Math.floor(Math.random() * 100)}`;
                }
                const metadata = await fetchYouTubeMetadata(link);
                const newId = Date.now() + '-' + Math.random().toString(36);
                database.ref(`series/${newId}`).set({
                    id: newId,
                    title: `${serieName} - ${episodeTitle}`,
                    link: link,
                    thumb: metadata?.thumb || 'https://via.placeholder.com/300x200',
                    category: metadata?.genre || 'Série',
                    year: metadata?.year || new Date().getFullYear(),
                    description: metadata?.description || ''
                });
            }
            showToast('Episódios adicionados!');
            document.getElementById('serieTitle').value = '';
            document.getElementById('episodesLinksInput').value = '';
        }
        
        async function saveItemFromForm() {
            const title = document.getElementById('itemTitle').value.trim();
            const link = document.getElementById('itemLink').value.trim();
            const thumb = document.getElementById('itemThumb').value.trim();
            const category = document.getElementById('itemCategory').value.trim();
            const year = document.getElementById('itemYear').value.trim();
            if(!title || !link) { alert('Preencha título e link'); return; }
            
            const activeAdminTab = document.querySelector('#adminPanel .admin-tab-btn.border-b-2.border-red-600')?.id;
            const newId = Date.now() + '-' + Math.random().toString(36);
            const newItem = { id: newId, title, link, thumb: thumb || 'https://via.placeholder.com/300x200', category: category || 'Geral', year, description: 'Adicionado via Admin' };
            
            if(activeAdminTab === 'adminTabCanais') database.ref(`canais/${newId}`).set(newItem);
            else if(activeAdminTab === 'adminTabFilmes') database.ref(`filmes/${newId}`).set(newItem);
            else if(activeAdminTab === 'adminTabSeries') database.ref(`series/${newId}`).set(newItem);
            showToast('Conteúdo adicionado!');
            resetForm();
        }
        
        function resetForm() {
            document.getElementById('itemTitle').value = '';
            document.getElementById('itemLink').value = '';
            document.getElementById('itemThumb').value = '';
            document.getElementById('itemCategory').value = '';
            document.getElementById('itemYear').value = '';
            editingItem = null;
            document.getElementById('cancelEditBtn').classList.add('hidden');
        }
        
        async function autoFillFromYoutubeLink() {
            const link = document.getElementById('itemLink').value.trim();
            if(!link || !extractYoutubeId(link)) return;
            const metadata = await fetchYouTubeMetadata(link);
            if(metadata) {
                document.getElementById('itemTitle').value = metadata.title;
                document.getElementById('itemThumb').value = metadata.thumb;
                document.getElementById('itemCategory').value = metadata.genre;
                document.getElementById('itemYear').value = metadata.year;
            }
        }
        
        // Event Listeners
        document.getElementById('navCanaisBtn').onclick = () => setNavTab('canais');
        document.getElementById('navFilmesBtn').onclick = () => setNavTab('filmes');
        document.getElementById('navSeriesBtn').onclick = () => setNavTab('series');
        document.getElementById('navSearchBtn').onclick = openSearchPopup;
        document.getElementById('closeSearchPopup').onclick = () => document.getElementById('searchPopup').classList.add('hidden');
        document.getElementById('closePlayerBtn').onclick = () => document.getElementById('playerSection').classList.add('hidden');
        document.getElementById('likeButton').onclick = toggleLike;
        document.getElementById('saveButton').onclick = toggleSave;
        document.getElementById('favoritesBtn').onclick = () => { const favs = favoritos.filter(f => f.saved); if(favs.length === 0) alert('Nenhum favorito'); else alert('Favoritos:\n' + favs.map(f => `⭐ ${f.title}`).join('\n')); };
        document.getElementById('sendMessageBtn').onclick = sendChatMessage;
        document.getElementById('chatInput').addEventListener('keypress', (e) => { if(e.key === 'Enter') sendChatMessage(); });
        
        // Minimizar chat
        let minimized = false;
        document.getElementById('chatHeader').onclick = () => {
            const container = document.getElementById('chatContainer');
            minimized = !minimized;
            if (minimized) {
                container.classList.add('minimized');
                document.getElementById('chatMessages').style.display = 'none';
                document.querySelector('.chat-input-area').style.display = 'none';
            } else {
                container.classList.remove('minimized');
                document.getElementById('chatMessages').style.display = 'flex';
                document.querySelector('.chat-input-area').style.display = 'flex';
            }
        };
        
        // Auth eventos
        document.getElementById('doLogin').onclick = () => {
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;
            auth.signInWithEmailAndPassword(email, password).catch(e => showToast('Erro: ' + e.message));
        };
        
        document.getElementById('doRegister').onclick = () => {
            const email = document.getElementById('registerEmail').value;
            const password = document.getElementById('registerPassword').value;
            auth.createUserWithEmailAndPassword(email, password).catch(e => showToast('Erro: ' + e.message));
        };
        
        document.getElementById('showRegister').onclick = () => {
            document.getElementById('loginForm').classList.add('hidden');
            document.getElementById('registerForm').classList.remove('hidden');
        };
        
        document.getElementById('showLogin').onclick = () => {
            document.getElementById('registerForm').classList.add('hidden');
            document.getElementById('loginForm').classList.remove('hidden');
        };
        
        document.getElementById('logoutBtn').onclick = () => auth.signOut();
        
        // Admin modal
        const modal = document.getElementById('adminModal');
        document.getElementById('adminBtn').onclick = () => { modal.classList.remove('hidden'); document.getElementById('adminLoginArea').classList.remove('hidden'); document.getElementById('adminPanel').classList.add('hidden'); };
        document.getElementById('closeAdminModal').onclick = () => modal.classList.add('hidden');
        document.getElementById('loginAdminBtn').onclick = () => { if(document.getElementById('adminPassword').value === 'admin123') { isAdminLogged = true; document.getElementById('adminLoginArea').classList.add('hidden'); document.getElementById('adminPanel').classList.remove('hidden'); refreshAdminLists(); } else alert('Senha incorreta'); };
        
        document.getElementById('adminTabCanais').onclick = () => { 
            document.querySelectorAll('.admin-tab-btn').forEach(btn => btn.classList.remove('border-b-2', 'border-red-600', 'text-red-500')); 
            document.getElementById('adminTabCanais').classList.add('border-b-2', 'border-red-600', 'text-red-500');
            document.getElementById('adminCanaisList').classList.remove('hidden');
            document.getElementById('adminFilmesList').classList.add('hidden');
            document.getElementById('adminSeriesList').classList.add('hidden');
            document.getElementById('batchFilmesArea').classList.add('hidden');
            document.getElementById('batchSeriesArea').classList.add('hidden');
            resetForm();
        };
        
        document.getElementById('adminTabFilmes').onclick = () => { 
            document.querySelectorAll('.admin-tab-btn').forEach(btn => btn.classList.remove('border-b-2', 'border-red-600', 'text-red-500')); 
            document.getElementById('adminTabFilmes').classList.add('border-b-2', 'border-red-600', 'text-red-500');
            document.getElementById('adminCanaisList').classList.add('hidden');
            document.getElementById('adminFilmesList').classList.remove('hidden');
            document.getElementById('adminSeriesList').classList.add('hidden');
            document.getElementById('batchFilmesArea').classList.remove('hidden');
            document.getElementById('batchSeriesArea').classList.add('hidden');
            resetForm();
        };
        
        document.getElementById('adminTabSeries').onclick = () => { 
            document.querySelectorAll('.admin-tab-btn').forEach(btn => btn.classList.remove('border-b-2', 'border-red-600', 'text-red-500')); 
            document.getElementById('adminTabSeries').classList.add('border-b-2', 'border-red-600', 'text-red-500');
            document.getElementById('adminCanaisList').classList.add('hidden');
            document.getElementById('adminFilmesList').classList.add('hidden');
            document.getElementById('adminSeriesList').classList.remove('hidden');
            document.getElementById('batchFilmesArea').classList.add('hidden');
            document.getElementById('batchSeriesArea').classList.remove('hidden');
            resetForm();
        };
        
        document.getElementById('saveItemBtn').onclick = saveItemFromForm;
        document.getElementById('cancelEditBtn').onclick = resetForm;
        document.getElementById('itemLink').addEventListener('blur', autoFillFromYoutubeLink);
        document.getElementById('previewBatchBtn').onclick = previewBatch;
        document.getElementById('saveBatchBtn').onclick = saveBatch;
        document.getElementById('saveEpisodesBtn').onclick = saveEpisodes;
        document.getElementById('castButton').onclick = () => showToast('Conecte-se a um Chromecast na mesma rede');
        
        // Inicialização
        auth.onAuthStateChanged((user) => {
            currentUser = user;
            updateUserUI(user);
        });
        
        setupSearchPopup();
        document.getElementById('batchSeriesArea').classList.add('hidden');
        
        if(typeof YT === 'undefined') {
            window.onYouTubeIframeAPIReady = onYouTubeIframeAPIReady;
        } else {
            onYouTubeIframeAPIReady();
        }
        
        document.getElementById('searchPopup').addEventListener('click', (e) => {
            if(e.target === document.getElementById('searchPopup')) {
                document.getElementById('searchPopup').classList.add('hidden');
            }
        });
        
        // Simular usuários online
        setInterval(() => {
            const onlineCount = Math.floor(Math.random() * 20) + 5;
            document.getElementById('onlineCount').innerHTML = `● ${onlineCount} online`;
        }, 10000);
    </script>
</body>
</html>
